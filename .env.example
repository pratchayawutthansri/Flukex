# Demo mode only. No secrets are required.
NEXT_PUBLIC_DATA_PROVIDER=mock
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_REALTIME=broadcast-channel
NEXT_PUBLIC_LINE_ADD_FRIEND_URL=https://line.me/R/ti/p/@your-line-id

# Supabase mode (set NEXT_PUBLIC_DATA_PROVIDER=supabase to enable).
# Never commit real values for these — fill them in .env.local only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
